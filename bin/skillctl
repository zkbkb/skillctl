#!/usr/bin/env bash
set -euo pipefail

# skillctl — Unified AI coding tool skill manager
# Manages a canonical ~/.skills/ directory and federates symlinks
# to all AI tool skill directories (~/.claude/skills, ~/.codex/skills, etc.)

VERSION="0.2.0"
SKILLS_ROOT="${SKILLS_ROOT:-$HOME/.skills}"
REGISTRY_FILE="$SKILLS_ROOT/.registry.json"

# Defaults (must be set before sourcing libs, which reference these)
QUIET=false
DRY_RUN=false

# Source library modules
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/utils.sh"
source "$LIB_DIR/registry.sh"
source "$LIB_DIR/sync.sh"
source "$LIB_DIR/manage.sh"
source "$LIB_DIR/discover.sh"
source "$LIB_DIR/tools.sh"
source "$LIB_DIR/tui.sh"

# ─── Main CLI ───────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
skillctl — Unified AI skill directory manager

Usage:
  skillctl <command> [options]

Commands:
  manage                Interactive skill browser and manager (fzf TUI)
  scan                  Discover AI tools on this system
  tools                 List discovered tools and sync modes
  tools set <t> <mode>  Set tool sync mode (all/selective/ignore/external)
  tools select <t> ...  Set which skills a tool receives (selective mode)
  sync                  Rebuild all/ index and tool directory symlinks
  status                Health check: counts, broken links, drift
  list [filter]         List all skills with category and source
  add <path>            Add a skill directory to user/ and sync
  remove <name>         Remove a skill and clean all links
  doctor                Fix broken links, normalize names
  init                  Initialize ~/.skills/ directory structure
  migrate               Migrate skills from scattered directories into ~/.skills/
  version               Show version

Options:
  --quiet, -q   Suppress non-error output
  --dry-run     Show what would be done without doing it
  --help, -h    Show this help

Environment:
  SKILLS_ROOT   Override canonical directory (default: ~/.skills)
EOF
}

# Parse global options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --quiet|-q) QUIET=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --help|-h) usage; exit 0 ;;
        --version) echo "skillctl $VERSION"; exit 0 ;;
        -*) echo "Unknown option: $1" >&2; usage; exit 1 ;;
        *) break ;;
    esac
done

# Load config (silently — warnings handled inside)
load_config 2>/dev/null || true

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    manage)     cmd_manage "$@" ;;
    menu)       _main_menu ;;
    browse)     cmd_browse "$@" ;;
    scan)       cmd_scan "$@" ;;
    tools)      cmd_tools "$@" ;;
    init)       cmd_init "$@" ;;
    migrate)    cmd_migrate "$@" ;;
    sync)       cmd_sync "$@" ;;
    status)     cmd_status "$@" ;;
    list)       cmd_list "$@" ;;
    add)        cmd_add "$@" ;;
    remove)     cmd_remove "$@" ;;
    doctor)     cmd_doctor "$@" ;;
    version)    echo "skillctl $VERSION" ;;
    "")         cmd_manage "$@" ;;
    *)          echo "Unknown command: $COMMAND" >&2; usage; exit 1 ;;
esac
